# 张雪峰视角智能体 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# === 模型后端 ===
# 选择: ollama 或 bailian
BACKEND=ollama
MODEL_NAME=qwen3:8b

# === 阿里云百炼 API（使用 bailian 后端时必填）===
DASHSCOPE_API_KEY=sk-your-api-key-here

# === API 服务配置 ===
API_HOST=0.0.0.0
API_PORT=8000

# === API 认证密钥（客户端调用 API 时需携带） ===
# 留空则不启用认证（仅开发环境使用）
API_SECRET_KEY=

# === CORS 允许的前端域名（逗号分隔） ===
# 生产环境请指定具体域名，如 https://your-domain.com
CORS_ORIGINS=*

# === 会话配置 ===
# 会话存储路径（SQLite数据库）
SESSION_DB_PATH=./data/sessions.db
# 会话过期时间（秒），默认24小时
SESSION_TTL=86400
# 最大会话数
MAX_SESSIONS=1000
